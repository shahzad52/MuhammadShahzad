    columns={2}
    items={[
      {
        title: 'AI / ML & Python',
        description: 'LangChain & RAG, BERT Classification, Hugging Face, Pinecone, TensorFlow, Scikit-Learn, OpenAI API, Llama models.',
        icon: 'tabler:robot',
      },
      {
        title: 'Web Scraping',
