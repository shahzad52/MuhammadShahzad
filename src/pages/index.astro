      // Toggle active class
      filterButtons.forEach(b => {
        b.classList.remove('bg-blue-600', 'text-white', 'border-blue-600');
        b.classList.add('border-gray-200', 'dark:border-slate-800');
      });
      btn.classList.add('bg-blue-600', 'text-white', 'border-blue-600');
      btn.classList.remove('border-gray-200', 'dark:border-slate-800');

      const filterValue = btn.getAttribute('data-filter');

      projectCards.forEach(card => {
        const cat = card.getAttribute('data-cat');
        if (filterValue === 'all' || cat === filterValue) {
          card.style.display = 'flex';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });

  // Pipeline Stepper logic
  const steps = {
    trigger: {
      title: "1. Webhook / Cron Trigger",
      desc: "n8n monitors external events — YouTube uploads or scheduled crons. Once fired, it pulls raw metadata and boots the execution chain securely."
    },
    scrape: {
      title: "2. Clean Data Scraping",
      desc: "A Python BeautifulSoup/Selenium worker fetches live web data — specs, prices, articles. It cleans and normalizes raw HTML while seamlessly bypasses basic bot-detection."
    },
    ai: {
      title: "3. ML Classification & Embeddings",
      desc: "BERT models classify difficulty/content. LangChain RAG chains fact-check context. Hugging Face embeddings are generated for semantic search."
    },
    db: {
      title: "4. Database Sync",
      desc: "Embeddings load into Pinecone for semantic search. Structured records sync to MongoDB and PostgreSQL, closing the automation loop cleanly."
    }
  };

  const stepButtons = document.querySelectorAll('.pipeline-step');
  const stepTitle = document.getElementById('step-title');
  const stepDesc = document.getElementById('step-desc');

  stepButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Remove active classes
      stepButtons.forEach(b => {
        const innerCircle = b.querySelector('div');
        const textSpan = b.querySelector('span:last-child');
        innerCircle.classList.remove('bg-blue-50', 'dark:bg-slate-800', 'text-blue-600', 'dark:text-blue-400', 'border-blue-600', 'dark:border-blue-400', 'shadow-md');
        innerCircle.classList.add('bg-gray-50', 'dark:bg-slate-900', 'text-slate-500', 'border-transparent');
        textSpan.classList.remove('text-slate-800', 'dark:text-white');
        textSpan.classList.add('text-slate-500', 'dark:text-slate-400');
      });

      // Add active class to clicked
      const circle = btn.querySelector('div');
      const text = btn.querySelector('span:last-child');
      circle.classList.add('bg-blue-50', 'dark:bg-slate-800', 'text-blue-600', 'dark:text-blue-400', 'border-blue-600', 'dark:border-blue-400', 'shadow-md');
      circle.classList.remove('bg-gray-50', 'dark:bg-slate-900', 'text-slate-500', 'border-transparent');
      text.classList.add('text-slate-800', 'dark:text-white');
      text.classList.remove('text-slate-500', 'dark:text-slate-400');

      const stepKey = btn.getAttribute('data-step');
      const data = steps[stepKey];
      if (stepTitle && stepDesc && data) {
        stepTitle.textContent = data.title;
        stepDesc.textContent = data.desc;
      }
    });
  });

  // Contact Form Submission
  const form = document.getElementById('contact-form');
  const toast = document.getElementById('form-toast');

  if (form && toast) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) {
        submitBtn.textContent = 'Sending...';
        submitBtn.disabled = true;
      }

      setTimeout(() => {
        toast.className = 'p-4 rounded-lg text-sm mb-4 bg-emerald-100 text-emerald-800 border border-emerald-200 dark:bg-emerald-900/30 dark:text-emerald-300 dark:border-emerald-800';
        toast.textContent = "Got it! I'll reach out via WhatsApp or email shortly.";
        toast.classList.remove('hidden');

        form.reset();
        
        if (submitBtn) {
          submitBtn.textContent = 'Send Message';
          submitBtn.disabled = false;
        }
      }, 1000);
    });
  }
</script>
