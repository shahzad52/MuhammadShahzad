---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Steps from '~/components/widgets/Steps.astro';
import Stats from '~/components/widgets/Stats.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Muhammad Shahzad — AI Automation & Data Engineer',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'View Projects',
        href: '#projects',
        icon: 'tabler:arrow-down',
      },
      {
        text: 'Contact Me',
        href: 'mailto:imshahzad52@gmail.com?subject=Project Inquiry',
        target: '_blank',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">
      <span id="typewriter-title" class="inline-block text-accent dark:text-blue-400 border-r-2 border-accent dark:border-blue-400 pr-1"></span>
    </Fragment>

    <Fragment slot="subtitle">
      Data Scientist with 1.5+ years of experience building resilient Python AI pipelines,
      robust data harvesting tools, workflow automation systems, and high-performance full-stack web applications.
      <br class="hidden md:inline" /> Based in Lahore — working globally.
    </Fragment>

    <Fragment slot="content">
      <div class="mt-4 flex flex-wrap justify-center gap-2 max-w-lg mx-auto">
        <span class="px-3 py-1 text-xs font-mono bg-blue-100 dark:bg-slate-800 text-blue-800 dark:text-blue-300 rounded-full border border-blue-200 dark:border-slate-700">Python</span>
        <span class="px-3 py-1 text-xs font-mono bg-blue-100 dark:bg-slate-800 text-blue-800 dark:text-blue-300 rounded-full border border-blue-200 dark:border-slate-700">Next.js</span>
        <span class="px-3 py-1 text-xs font-mono bg-blue-100 dark:bg-slate-800 text-blue-800 dark:text-blue-300 rounded-full border border-blue-200 dark:border-slate-700">Automation</span>
        <span class="px-3 py-1 text-xs font-mono bg-blue-100 dark:bg-slate-800 text-blue-800 dark:text-blue-300 rounded-full border border-blue-200 dark:border-slate-700">Ruby on Rails</span>
        <span class="px-3 py-1 text-xs font-mono bg-blue-100 dark:bg-slate-800 text-blue-800 dark:text-blue-300 rounded-full border border-blue-200 dark:border-slate-700">MongoDB</span>
      </div>
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->
  <Stats
    stats={[
      { title: 'Years Experience', amount: '1.5+' },
      { title: 'Price Sync Categories', amount: '40+' },
      { title: 'Client Projects Shipped', amount: '5+' },
      { title: 'Role', amount: 'Data Scientist' },
    ]}
  />

  <!-- About Section ***************** -->
  <section id="about" class="py-16 md:py-24 bg-blue-50/30 dark:bg-slate-900/30 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-base text-accent dark:text-blue-400 font-bold tracking-wide uppercase">Background</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight font-heading mt-2 mb-6">About My Work</h2>
          <div class="text-lg text-muted dark:text-slate-400 space-y-4">
            <p>
              I turn messy, manual workflows into clean, automated systems. My background in 
              <strong>Data Science</strong> gave me a solid foundation in how ML models, 
              embeddings, and classification actually work — not just how to call an API.
            </p>
            <p>
              Day-to-day I build web apps with Next.js and Ruby on Rails, write robust data 
              harvesting pipelines in Python, coordinate automated multi-agent workflow systems, 
              and integrate AI layers using vector databases.
            </p>
            <blockquote class="border-l-4 border-accent pl-4 italic text-slate-700 dark:text-slate-300 bg-accent/5 py-2 pr-2 rounded-r-md">
              "Clean exception handling in scrapers, proper RAG context windows, functional 
              AI flows that solve real problems — not demos that break in production."
            </blockquote>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-900 p-8 rounded-2xl border border-gray-200 dark:border-slate-800 shadow-sm relative overflow-hidden">
          <div class="absolute top-0 left-0 w-2 h-full bg-gradient-to-b from-blue-600 to-emerald-500"></div>
          <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
            <Icon name="tabler:school" class="w-6 h-6 text-accent dark:text-blue-400" /> Education & Certifications
          </h3>
          <div class="space-y-6">
            <div>
              <h4 class="font-bold text-lg">B.S. Data Science</h4>
              <p class="text-accent dark:text-blue-400 font-medium">Graduated (2021 – 2025)</p>
              <p class="text-muted dark:text-slate-400 text-sm mt-1">
                Lahore, Pakistan · Supervised ML, Deep Learning, MLOps, NLP, Vector Embeddings, Database Architecture.
              </p>
            </div>
            <hr class="border-gray-200 dark:border-slate-800" />
            <ul class="space-y-3">
              <li class="flex items-center gap-2 text-sm text-slate-700 dark:text-slate-300">
                <Icon name="tabler:circle-check" class="w-4 h-4 text-emerald-500" /> Supervised Machine Learning — Coursera
              </li>
              <li class="flex items-center gap-2 text-sm text-slate-700 dark:text-slate-300">
                <Icon name="tabler:circle-check" class="w-4 h-4 text-emerald-500" /> MLOps: MLflow & Hugging Face — Coursera
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Stack Widget ******** -->
  <Features3
    id="skills"
    tagline="Capabilities"
    title="Technical Stack"
    subtitle="Tools I reach for regularly — not a keyword dump."
    columns={2}
    items={[
      {
        title: 'AI / ML & Python',
        description: 'LangChain & RAG, BERT Classification, Hugging Face, Pinecone, TensorFlow, Scikit-Learn, OpenAI API, Llama models.',
        icon: 'tabler:robot',
      },
      {
        title: 'Web Scraping',
        description: 'Robust web crawlers, BeautifulSoup, Selenium, Anti-bot bypass mechanisms, API reverse engineering, Cron automation, Data validation.',
        icon: 'tabler:spider',
      },
      {
        title: 'Web Engineering',
        description: 'Next.js, React, Ruby on Rails, Flask, Django, PostgreSQL, MongoDB, Docker, Vercel optimization, Local SEO.',
        icon: 'tabler:world',
      },
      {
        title: 'Automation & Ops',
        description: 'Workflow automation orchestration, Webhook-driven event pipelines, API integrations, Multi-agent system flows, GitHub Actions CI/CD.',
        icon: 'tabler:settings',
      },
    ]}
  />

  <!-- Experience Timeline Widget **** -->
  <Steps
    id="experience"
    title="Professional Experience"
    items={[
      {
        title: 'AI Developer & Data Pipeline Engineer <br /> <span class="font-normal text-muted dark:text-slate-400">Software & Automation Engineering (2024 - Present)</span>',
        description: `• Configured Pinecone vector indexes and Hugging Face embeddings for context-aware student search query matching.
                      <br />• Wrote resilient data harvesting scrapers for JavaScript-heavy sites with automatic DOM-change recovery.
                      <br />• Built daily automated price sync scrapers for 47 device categories, writing cleaned records directly to MongoDB.
                      <br />• Designed webhook-driven automation workflows: Media upload → automatic transcript extraction → AI categorization → dashboard synchronization.
                      <br />• Shipped high-performance responsive client websites for lawn care businesses with customized local SEO structures.`,
        icon: 'tabler:briefcase',
      },
    ]}
    classes={{ container: 'max-w-4xl scroll-mt-20' }}
  />

  <!-- Projects Grid Section ********* -->
  <section id="projects" class="py-16 md:py-24 bg-blue-50/30 dark:bg-slate-900/30 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-base text-accent dark:text-blue-400 font-bold tracking-wide uppercase">Portfolio</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight font-heading mt-2 mb-4">Selected Projects</h2>
        <p class="text-xl text-muted dark:text-slate-400">Real builds — not toy demos.</p>
      </div>

      <!-- Filter Controls -->
      <div class="flex flex-wrap justify-center gap-2 mb-10" id="project-filters">
        <button class="px-4 py-1.5 rounded-full text-sm font-semibold border bg-blue-600 text-white border-blue-600" data-filter="all">All</button>
        <button class="px-4 py-1.5 rounded-full text-sm font-semibold border border-gray-200 dark:border-slate-800 hover:border-accent hover:text-accent dark:hover:text-blue-400" data-filter="ai-ml">AI/ML</button>
        <button class="px-4 py-1.5 rounded-full text-sm font-semibold border border-gray-200 dark:border-slate-800 hover:border-accent hover:text-accent dark:hover:text-blue-400" data-filter="web-scraping">Web Scraping</button>
        <button class="px-4 py-1.5 rounded-full text-sm font-semibold border border-gray-200 dark:border-slate-800 hover:border-accent hover:text-accent dark:hover:text-blue-400" data-filter="automation">Automation</button>
        <button class="px-4 py-1.5 rounded-full text-sm font-semibold border border-gray-200 dark:border-slate-800 hover:border-accent hover:text-accent dark:hover:text-blue-400" data-filter="full-stack-web">Full-Stack Web</button>
      </div>

      <!-- Grid -->
      <div class="grid md:grid-cols-2 gap-8" id="project-grid">
        <!-- Project 1 -->
        <article class="bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition duration-300 flex flex-col" data-cat="ai-ml">
          <div class="h-40 bg-slate-100 dark:bg-slate-800 flex items-center justify-center border-b border-gray-200 dark:border-slate-800 relative">
            <Icon name="tabler:scale" class="w-12 h-12 text-blue-600 dark:text-blue-400" />
          </div>
          <div class="p-6 flex-1 flex flex-col justify-between">
            <div>
              <span class="text-xs font-bold uppercase tracking-wider text-emerald-600 dark:text-emerald-400">AI/ML</span>
              <h3 class="text-xl font-bold mt-1 mb-2">FileIt</h3>
              <p class="text-muted dark:text-slate-400 text-sm leading-relaxed mb-4">
                Legal document NLP analyzer. Extracts entities from legal briefs, providing constitutional references via localized vector search. Flask + PostgreSQL backend.
              </p>
            </div>
            <div>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {['Flask', 'PostgreSQL', 'NLP', 'Spacy', 'Vector Search'].map(t => (
                  <span class="px-2 py-0.5 text-xs font-mono bg-gray-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 rounded">{t}</span>
                ))}
              </div>
              <a href="https://github.com/Shahzad52" target="_blank" class="text-sm font-semibold text-accent dark:text-blue-400 inline-flex items-center gap-1 hover:underline">
                View on GitHub →
              </a>
            </div>
          </div>
        </article>

        <!-- Project 2 -->
        <article class="bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition duration-300 flex flex-col" data-cat="web-scraping">
          <div class="h-40 bg-slate-100 dark:bg-slate-800 flex items-center justify-center border-b border-gray-200 dark:border-slate-800 relative">
            <Icon name="tabler:device-mobile" class="w-12 h-12 text-blue-600 dark:text-blue-400" />
          </div>
          <div class="p-6 flex-1 flex flex-col justify-between">
            <div>
              <span class="text-xs font-bold uppercase tracking-wider text-emerald-600 dark:text-emerald-400">Web Scraping</span>
              <h3 class="text-xl font-bold mt-1 mb-2">MobileOye Price Sync</h3>
              <p class="text-muted dark:text-slate-400 text-sm leading-relaxed mb-4">
                Automated daily price sync across 47 mobile categories in Pakistan. Script-based data harvester pipelines, MongoDB writes, and Vercel serverless logs.
              </p>
            </div>
            <div>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {['Next.js', 'MongoDB', 'Python', 'Web Crawling'].map(t => (
                  <span class="px-2 py-0.5 text-xs font-mono bg-gray-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 rounded">{t}</span>
                ))}
              </div>
              <a href="https://github.com/Shahzad52" target="_blank" class="text-sm font-semibold text-accent dark:text-blue-400 inline-flex items-center gap-1 hover:underline">
                View on GitHub →
              </a>
            </div>
          </div>
        </article>

        <!-- Project 3 -->
        <article class="bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition duration-300 flex flex-col" data-cat="automation">
          <div class="h-40 bg-slate-100 dark:bg-slate-800 flex items-center justify-center border-b border-gray-200 dark:border-slate-800 relative">
            <Icon name="tabler:settings" class="w-12 h-12 text-blue-600 dark:text-blue-400" />
          </div>
          <div class="p-6 flex-1 flex flex-col justify-between">
            <div>
              <span class="text-xs font-bold uppercase tracking-wider text-emerald-600 dark:text-emerald-400">Automation</span>
              <h3 class="text-xl font-bold mt-1 mb-2">YouTube Automation Pipeline</h3>
              <p class="text-muted dark:text-slate-400 text-sm leading-relaxed mb-4">
                Webhook-driven workflow: YouTube upload triggers raw transcript fetching, processed by a language model agent to write structured summaries to web dashboards.
              </p>
            </div>
            <div>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {['API Integrations', 'Webhooks', 'YouTube API', 'AI Agents'].map(t => (
                  <span class="px-2 py-0.5 text-xs font-mono bg-gray-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 rounded">{t}</span>
                ))}
              </div>
              <a href="https://github.com/Shahzad52" target="_blank" class="text-sm font-semibold text-accent dark:text-blue-400 inline-flex items-center gap-1 hover:underline">
                View on GitHub →
              </a>
            </div>
          </div>
        </article>

        <!-- Project 4 -->
        <article class="bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition duration-300 flex flex-col" data-cat="full-stack-web">
          <div class="h-40 bg-slate-100 dark:bg-slate-800 flex items-center justify-center border-b border-gray-200 dark:border-slate-800 relative">
            <Icon name="tabler:leaf" class="w-12 h-12 text-blue-600 dark:text-blue-400" />
          </div>
          <div class="p-6 flex-1 flex flex-col justify-between">
            <div>
              <span class="text-xs font-bold uppercase tracking-wider text-emerald-600 dark:text-emerald-400">Full-Stack Web</span>
              <h3 class="text-xl font-bold mt-1 mb-2">Lawn Care Websites</h3>
              <p class="text-muted dark:text-slate-400 text-sm leading-relaxed mb-4">
                Responsive service sites for local lawn care businesses. Core Web Vitals optimized, local SEO structured, with lead routing via secure email handlers.
              </p>
            </div>
            <div>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {['Next.js', 'React', 'Vercel', 'SEO'].map(t => (
                  <span class="px-2 py-0.5 text-xs font-mono bg-gray-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 rounded">{t}</span>
                ))}
              </div>
              <a href="https://github.com/Shahzad52" target="_blank" class="text-sm font-semibold text-accent dark:text-blue-400 inline-flex items-center gap-1 hover:underline">
                View on GitHub →
              </a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Contact Section *************** -->
  <section id="contact" class="py-16 md:py-24 bg-blue-50/30 dark:bg-slate-900/30 scroll-mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-base text-accent dark:text-blue-400 font-bold tracking-wide uppercase">Get In Touch</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight font-heading mt-2 mb-4">Let's Talk</h2>
          <p class="text-lg text-muted dark:text-slate-400 mb-8">
            Fastest reply via email. Drop a message or mail me directly, and I'll respond within a few hours.
          </p>

          <div class="space-y-4">
            <a href="mailto:imshahzad52@gmail.com?subject=Project Inquiry" class="flex items-center gap-4 p-4 rounded-xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-accent hover:shadow-sm transition">
              <Icon name="tabler:mail" class="w-8 h-8 text-blue-500" />
              <div>
                <h4 class="text-xs uppercase font-bold text-slate-400">Email</h4>
                <p class="font-bold text-slate-800 dark:text-white">imshahzad52@gmail.com</p>
              </div>
            </a>
            <a href="https://github.com/Shahzad52" target="_blank" class="flex items-center gap-4 p-4 rounded-xl border border-gray-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-accent hover:shadow-sm transition">
              <Icon name="tabler:brand-github" class="w-8 h-8 text-slate-500" />
              <div>
                <h4 class="text-xs uppercase font-bold text-slate-400">GitHub</h4>
                <p class="font-bold text-slate-800 dark:text-white">github.com/Shahzad52</p>
              </div>
            </a>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-900 border border-gray-200 dark:border-slate-800 p-8 rounded-2xl shadow-sm">
          <h3 class="text-xl font-bold mb-6">Send a Message</h3>
          <form id="contact-form" class="space-y-4">
            <div id="form-toast" class="hidden p-4 rounded-lg text-sm mb-4"></div>
            
            <div>
              <label class="block text-sm font-semibold mb-1 text-slate-700 dark:text-slate-300">Name</label>
              <input type="text" id="name" required class="w-full px-4 py-2 border border-gray-200 dark:border-slate-800 rounded-lg bg-white dark:bg-slate-950 focus:outline-none focus:border-accent" placeholder="Your Name" />
            </div>
            <div>
              <label class="block text-sm font-semibold mb-1 text-slate-700 dark:text-slate-300">Email</label>
              <input type="email" id="email" required class="w-full px-4 py-2 border border-gray-200 dark:border-slate-800 rounded-lg bg-white dark:bg-slate-950 focus:outline-none focus:border-accent" placeholder="your@email.com" />
            </div>
            <div>
              <label class="block text-sm font-semibold mb-1 text-slate-700 dark:text-slate-300">Message</label>
              <textarea id="message" required rows="4" class="w-full px-4 py-2 border border-gray-200 dark:border-slate-800 rounded-lg bg-white dark:bg-slate-950 focus:outline-none focus:border-accent" placeholder="What do you need built?"></textarea>
            </div>
            <button type="submit" class="w-full py-3 bg-accent text-white font-semibold rounded-lg hover:bg-accent-hover transition shadow-sm">
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Typewriter Animation
  const text = "AI Automation & Data Engineering";
  const speed = 100;
  let i = 0;
  const target = document.getElementById('typewriter-title');
  if (target) {
    function typeWriter() {
      if (i < text.length) {
        target.innerHTML += text.charAt(i);
        i++;
        setTimeout(typeWriter, speed);
      } else {
        target.classList.remove('border-r-2');
      }
    }
    typeWriter();
  }

  // Filter logic
  const filterButtons = document.querySelectorAll('#project-filters button');
  const projectCards = document.querySelectorAll('#project-grid article');

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Toggle active class
      filterButtons.forEach(b => {
        b.classList.remove('bg-blue-600', 'text-white', 'border-blue-600');
        b.classList.add('border-gray-200', 'dark:border-slate-800');
      });
      btn.classList.add('bg-blue-600', 'text-white', 'border-blue-600');
      btn.classList.remove('border-gray-200', 'dark:border-slate-800');

      const filterValue = btn.getAttribute('data-filter');

      projectCards.forEach(card => {
        const cat = card.getAttribute('data-cat');
        if (filterValue === 'all' || cat === filterValue) {
          card.style.display = 'flex';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });

  // Contact Form Submission
  const form = document.getElementById('contact-form');
  const toast = document.getElementById('form-toast');

  if (form && toast) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) {
        submitBtn.textContent = 'Sending...';
        submitBtn.disabled = true;
      }

      setTimeout(() => {
        toast.className = 'p-4 rounded-lg text-sm mb-4 bg-emerald-100 text-emerald-800 border border-emerald-200 dark:bg-emerald-900/30 dark:text-emerald-300 dark:border-emerald-800';
        toast.textContent = "Got it! I'll reach out via email shortly.";
        toast.classList.remove('hidden');

        form.reset();
        
        if (submitBtn) {
          submitBtn.textContent = 'Send Message';
          submitBtn.disabled = false;
        }
      }, 1000);
    });
  }
</script>
