---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'Muhammad Shahzad — Developer & Data Engineer',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- Hero -->
  <section class="relative overflow-hidden" id="hero">
    <!-- Moving diagonal lines layer -->
    <div class="hero-lines-bg pointer-events-none" aria-hidden="true"></div>
    <!-- Radial mask so text stays readable -->
    <div class="hero-lines-mask pointer-events-none" aria-hidden="true"></div>
    <!-- Drifting colour wash top-left -->
    <div class="hero-wash absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full pointer-events-none opacity-60" aria-hidden="true"></div>
    <!-- Content -->
    <div class="relative z-10 pt-20 md:pt-32 pb-24 px-6 max-w-4xl mx-auto">
      <h1 class="text-5xl md:text-[3.75rem] font-bold leading-tight text-gray-900 mb-6" style="font-family:'DM Serif Display',Georgia,serif; letter-spacing:-0.03em;">
        <span id="tw-text"></span><span class="tw-cursor" id="tw-cursor"></span>
      </h1>
      <p class="text-xl text-gray-500 leading-relaxed max-w-2xl mb-10">
        I'm Shahzad — a developer based in Lahore. I work on data pipelines,
        AI integrations, web scraping, and full-stack apps. I like things that
        actually work in production.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="#projects" class="inline-flex items-center gap-2 bg-gray-900 text-white px-6 py-3 rounded-lg text-sm font-medium hover:bg-gray-700 transition-colors">
          See my work
        </a>
        <a href="mailto:imshahzad52@gmail.com?subject=Project Inquiry" class="inline-flex items-center gap-2 border border-gray-200 text-gray-700 px-6 py-3 rounded-lg text-sm font-medium hover:border-gray-400 hover:text-gray-900 transition-colors">
          Get in touch
        </a>
      </div>
    </div>
    <!-- bottom fade to body bg -->
    <div class="absolute bottom-0 left-0 right-0 h-28 pointer-events-none" style="background: linear-gradient(to bottom, transparent, rgb(250 250 252));"></div>
  </section>

  <!-- Divider -->
  <div class="max-w-4xl mx-auto px-6">
    <hr class="border-gray-100" />
  </div>

  <!-- About -->
  <section id="about" class="py-24 px-6 max-w-4xl mx-auto scroll-mt-20 reveal">
    <div class="grid md:grid-cols-5 gap-16">
      <div class="md:col-span-3">
        <h2 class="text-3xl font-bold text-gray-900 mb-6" style="font-family:'DM Serif Display',Georgia,serif;">A bit about me</h2>
        <div class="space-y-4 text-gray-600 leading-relaxed text-[1.05rem]">
          <p>
            I graduated with a B.S. in Data Science in 2025 and have spent the last year and a half
            doing the kind of work that doesn't make it into tutorials — building scrapers that survive
            DOM changes, writing AI pipelines that hold up under real load, and shipping client
            projects that I'm actually proud of.
          </p>
          <p>
            Day-to-day I write a lot of Python, work with Next.js and Ruby on Rails on the web side,
            and integrate things like vector databases and LLMs when there's a real reason to.
          </p>
          <p>
            I care about clean exception handling, useful abstractions, and code that someone else
            can actually maintain. Not just code that demos well.
          </p>
        </div>
      </div>
      <div class="md:col-span-2">
        <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
          <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-4">Education</h3>
          <div class="mb-5">
            <p class="font-semibold text-gray-900">B.S. Data Science</p>
            <p class="text-sm text-gray-500 mt-0.5">Lahore, Pakistan · 2021–2025</p>
            <p class="text-xs text-gray-400 mt-1">ML, Deep Learning, NLP, MLOps, Vector DBs</p>
          </div>
          <hr class="border-gray-100 mb-5" />
          <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-3">Certifications</h3>
          <ul class="space-y-2">
            <li class="flex items-start gap-2 text-sm text-gray-600">
              <Icon name="tabler:circle-check" class="w-4 h-4 text-indigo-500 mt-0.5 shrink-0" />
              Supervised Machine Learning — Coursera
            </li>
            <li class="flex items-start gap-2 text-sm text-gray-600">
              <Icon name="tabler:circle-check" class="w-4 h-4 text-indigo-500 mt-0.5 shrink-0" />
              MLOps: MLflow & Hugging Face — Coursera
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills" class="py-24 px-6 scroll-mt-20 reveal" style="background: linear-gradient(180deg, rgb(248 250 252) 0%, rgb(250 250 252) 100%); border-top: 1px solid rgb(241 245 249); border-bottom: 1px solid rgb(241 245 249);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 mb-3" style="font-family:'DM Serif Display',Georgia,serif;">What I work with</h2>
      <p class="text-gray-500 mb-12">The tools I reach for regularly — not a keyword dump.</p>
      <div class="grid sm:grid-cols-2 gap-6">
        <div class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 bg-indigo-50 rounded-lg flex items-center justify-center">
              <Icon name="tabler:robot" class="w-4 h-4 text-indigo-600" />
            </div>
            <h3 class="font-semibold text-gray-900">AI & Python</h3>
          </div>
          <p class="text-sm text-gray-500 leading-relaxed">LangChain, RAG pipelines, BERT classification, Hugging Face, Pinecone, TensorFlow, Scikit-Learn, OpenAI API, Llama models.</p>
        </div>
        <div class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 bg-indigo-50 rounded-lg flex items-center justify-center">
              <Icon name="tabler:spider" class="w-4 h-4 text-indigo-600" />
            </div>
            <h3 class="font-semibold text-gray-900">Web Scraping</h3>
          </div>
          <p class="text-sm text-gray-500 leading-relaxed">BeautifulSoup, Selenium, anti-bot bypass, API reverse engineering, cron automation, data validation pipelines.</p>
        </div>
        <div class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 bg-indigo-50 rounded-lg flex items-center justify-center">
              <Icon name="tabler:world" class="w-4 h-4 text-indigo-600" />
            </div>
            <h3 class="font-semibold text-gray-900">Web Engineering</h3>
          </div>
          <p class="text-sm text-gray-500 leading-relaxed">Next.js, React, Ruby on Rails, Flask, Django, PostgreSQL, MongoDB, Docker, Vercel, local SEO.</p>
        </div>
        <div class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 bg-indigo-50 rounded-lg flex items-center justify-center">
              <Icon name="tabler:settings" class="w-4 h-4 text-indigo-600" />
            </div>
            <h3 class="font-semibold text-gray-900">Automation</h3>
          </div>
          <p class="text-sm text-gray-500 leading-relaxed">Workflow automation, webhook-driven pipelines, API integrations, multi-agent systems, GitHub Actions CI/CD.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience" class="py-24 px-6 max-w-4xl mx-auto scroll-mt-20 reveal">
    <h2 class="text-3xl font-bold text-gray-900 mb-12" style="font-family:'DM Serif Display',Georgia,serif;">Experience</h2>
    <div class="relative pl-6 border-l border-gray-100">
      <div class="mb-2">
        <span class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-indigo-500 border-2 border-white shadow-sm"></span>
        <div class="flex flex-wrap items-baseline gap-3 mb-2">
          <h3 class="font-semibold text-gray-900 text-lg">AI Developer & Data Pipeline Engineer</h3>
          <span class="text-sm text-gray-400">2024 – Present</span>
        </div>
        <p class="text-sm font-medium text-indigo-600 mb-4">Software & Automation Engineering</p>
        <ul class="space-y-2.5 text-gray-600 text-[0.95rem] leading-relaxed">
          <li class="flex gap-2"><span class="text-gray-300 shrink-0">–</span>Set up Pinecone vector indexes and Hugging Face embeddings for student search query matching.</li>
          <li class="flex gap-2"><span class="text-gray-300 shrink-0">–</span>Wrote scrapers for JavaScript-heavy sites with automatic DOM-change recovery.</li>
          <li class="flex gap-2"><span class="text-gray-300 shrink-0">–</span>Built daily price sync scrapers across 47 mobile categories, writing directly to MongoDB.</li>
          <li class="flex gap-2"><span class="text-gray-300 shrink-0">–</span>Designed webhook-driven pipeline: media upload → transcript extraction → AI categorization → dashboard sync.</li>
          <li class="flex gap-2"><span class="text-gray-300 shrink-0">–</span>Shipped responsive client websites for local businesses with custom local SEO structures.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="py-24 px-6 scroll-mt-20 reveal" style="background: linear-gradient(180deg, rgb(248 250 252) 0%, rgb(250 250 252) 100%); border-top: 1px solid rgb(241 245 249); border-bottom: 1px solid rgb(241 245 249);">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 mb-3" style="font-family:'DM Serif Display',Georgia,serif;">Selected projects</h2>
      <p class="text-gray-500 mb-10">Real builds — not toy examples.</p>

      <!-- Filter -->
      <div class="flex flex-wrap gap-2 mb-10" id="project-filters">
        <button class="px-3 py-1.5 rounded-full text-sm border bg-gray-900 text-white border-gray-900" data-filter="all">All</button>
        <button class="px-3 py-1.5 rounded-full text-sm border border-gray-200 text-gray-600 hover:border-gray-400 hover:text-gray-900 transition-colors" data-filter="ai-ml">AI / ML</button>
        <button class="px-3 py-1.5 rounded-full text-sm border border-gray-200 text-gray-600 hover:border-gray-400 hover:text-gray-900 transition-colors" data-filter="web-scraping">Scraping</button>
        <button class="px-3 py-1.5 rounded-full text-sm border border-gray-200 text-gray-600 hover:border-gray-400 hover:text-gray-900 transition-colors" data-filter="automation">Automation</button>
        <button class="px-3 py-1.5 rounded-full text-sm border border-gray-200 text-gray-600 hover:border-gray-400 hover:text-gray-900 transition-colors" data-filter="full-stack-web">Full-Stack</button>
      </div>

      <div class="grid sm:grid-cols-2 gap-5" id="project-grid">
        <!-- FileIt -->
        <article class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 flex flex-col" data-cat="ai-ml">
          <div class="flex items-center justify-between mb-4">
            <span class="text-xs font-semibold text-indigo-500 uppercase tracking-widest">AI / ML</span>
            <a href="https://github.com/Shahzad52" target="_blank" class="text-gray-300 hover:text-gray-600 transition-colors">
              <Icon name="tabler:brand-github" class="w-4 h-4" />
            </a>
          </div>
          <h3 class="font-semibold text-gray-900 text-lg mb-2">FileIt</h3>
          <p class="text-sm text-gray-500 leading-relaxed flex-1">
            Legal document NLP analyzer. Extracts entities from legal briefs and serves constitutional references via localized vector search. Flask + PostgreSQL backend.
          </p>
          <div class="flex flex-wrap gap-1.5 mt-4">
            {['Flask', 'PostgreSQL', 'spaCy', 'Pinecone'].map(t => (
              <span class="px-2 py-0.5 text-xs bg-gray-50 text-gray-500 border border-gray-100 rounded font-mono">{t}</span>
            ))}
          </div>
        </article>

        <!-- MobileOye -->
        <article class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 flex flex-col" data-cat="web-scraping">
          <div class="flex items-center justify-between mb-4">
            <span class="text-xs font-semibold text-indigo-500 uppercase tracking-widest">Scraping</span>
            <a href="https://github.com/Shahzad52" target="_blank" class="text-gray-300 hover:text-gray-600 transition-colors">
              <Icon name="tabler:brand-github" class="w-4 h-4" />
            </a>
          </div>
          <h3 class="font-semibold text-gray-900 text-lg mb-2">MobileOye Price Sync</h3>
          <p class="text-sm text-gray-500 leading-relaxed flex-1">
            Daily automated price sync across 47 mobile categories in Pakistan. Script-based harvester pipelines, MongoDB writes, and Vercel serverless logs.
          </p>
          <div class="flex flex-wrap gap-1.5 mt-4">
            {['Next.js', 'MongoDB', 'Python', 'Cron'].map(t => (
              <span class="px-2 py-0.5 text-xs bg-gray-50 text-gray-500 border border-gray-100 rounded font-mono">{t}</span>
            ))}
          </div>
        </article>

        <!-- YouTube Pipeline -->
        <article class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 flex flex-col" data-cat="automation">
          <div class="flex items-center justify-between mb-4">
            <span class="text-xs font-semibold text-indigo-500 uppercase tracking-widest">Automation</span>
            <a href="https://github.com/Shahzad52" target="_blank" class="text-gray-300 hover:text-gray-600 transition-colors">
              <Icon name="tabler:brand-github" class="w-4 h-4" />
            </a>
          </div>
          <h3 class="font-semibold text-gray-900 text-lg mb-2">YouTube Automation Pipeline</h3>
          <p class="text-sm text-gray-500 leading-relaxed flex-1">
            Webhook-driven flow: upload triggers raw transcript fetching → LLM agent processes it → writes structured summaries to a web dashboard automatically.
          </p>
          <div class="flex flex-wrap gap-1.5 mt-4">
            {['Webhooks', 'YouTube API', 'AI Agents', 'Python'].map(t => (
              <span class="px-2 py-0.5 text-xs bg-gray-50 text-gray-500 border border-gray-100 rounded font-mono">{t}</span>
            ))}
          </div>
        </article>

        <!-- Lawn Care -->
        <article class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 flex flex-col" data-cat="full-stack-web">
          <div class="flex items-center justify-between mb-4">
            <span class="text-xs font-semibold text-indigo-500 uppercase tracking-widest">Full-Stack</span>
            <a href="https://github.com/Shahzad52" target="_blank" class="text-gray-300 hover:text-gray-600 transition-colors">
              <Icon name="tabler:brand-github" class="w-4 h-4" />
            </a>
          </div>
          <h3 class="font-semibold text-gray-900 text-lg mb-2">Lawn Care Websites</h3>
          <p class="text-sm text-gray-500 leading-relaxed flex-1">
            Responsive service sites for local lawn care businesses. Core Web Vitals optimized, structured local SEO, lead routing via secure email handlers.
          </p>
          <div class="flex flex-wrap gap-1.5 mt-4">
            {['Next.js', 'React', 'Vercel', 'Local SEO'].map(t => (
              <span class="px-2 py-0.5 text-xs bg-gray-50 text-gray-500 border border-gray-100 rounded font-mono">{t}</span>
            ))}
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-24 px-6 max-w-4xl mx-auto scroll-mt-20 reveal">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="text-3xl font-bold text-gray-900 mb-4" style="font-family:'DM Serif Display',Georgia,serif;">Let's work together</h2>
        <p class="text-gray-500 mb-8 leading-relaxed">
          I'm open to freelance projects, contract work, and interesting problems. 
          Fastest reply via email — usually within a few hours.
        </p>
        <div class="space-y-3">
          <a href="mailto:imshahzad52@gmail.com?subject=Project Inquiry" class="flex items-center gap-3 p-4 rounded-xl border border-gray-100 bg-gray-50 hover:bg-gray-100 transition-colors group">
            <div class="w-9 h-9 bg-white rounded-lg flex items-center justify-center shadow-sm border border-gray-100">
              <Icon name="tabler:mail" class="w-4 h-4 text-indigo-500" />
            </div>
            <div>
              <p class="text-xs text-gray-400 font-medium">Email</p>
              <p class="text-sm font-semibold text-gray-800">imshahzad52@gmail.com</p>
            </div>
          </a>
          <a href="https://github.com/Shahzad52" target="_blank" class="flex items-center gap-3 p-4 rounded-xl border border-gray-100 bg-gray-50 hover:bg-gray-100 transition-colors group">
            <div class="w-9 h-9 bg-white rounded-lg flex items-center justify-center shadow-sm border border-gray-100">
              <Icon name="tabler:brand-github" class="w-4 h-4 text-gray-600" />
            </div>
            <div>
              <p class="text-xs text-gray-400 font-medium">GitHub</p>
              <p class="text-sm font-semibold text-gray-800">github.com/Shahzad52</p>
            </div>
          </a>
        </div>
      </div>

      <div class="bg-white border border-gray-100 rounded-2xl p-8 shadow-sm">
        <h3 class="font-semibold text-gray-900 mb-5">Send a message</h3>
        <form id="contact-form" class="space-y-4">
          <div id="form-toast" class="hidden p-3 rounded-lg text-sm"></div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1.5">Name</label>
            <input type="text" id="name" required class="w-full px-3.5 py-2.5 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-100 focus:border-indigo-300 transition" placeholder="Your name" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1.5">Email</label>
            <input type="email" id="email" required class="w-full px-3.5 py-2.5 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-100 focus:border-indigo-300 transition" placeholder="you@example.com" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1.5">Message</label>
            <textarea id="message" required rows="4" class="w-full px-3.5 py-2.5 text-sm border border-gray-200 rounded-lg bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-100 focus:border-indigo-300 transition resize-none" placeholder="What are you working on?"></textarea>
          </div>
          <button type="submit" class="w-full py-2.5 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors">
            Send message
          </button>
        </form>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Project filter
  const filterBtns = document.querySelectorAll('#project-filters button');
  const projectCards = document.querySelectorAll('#project-grid article');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => {
        b.classList.remove('bg-gray-900', 'text-white', 'border-gray-900');
        b.classList.add('border-gray-200', 'text-gray-600');
      });
      btn.classList.add('bg-gray-900', 'text-white', 'border-gray-900');
      btn.classList.remove('border-gray-200', 'text-gray-600');

      const val = btn.getAttribute('data-filter');
      projectCards.forEach(card => {
        const cat = card.getAttribute('data-cat');
        (card as HTMLElement).style.display = (val === 'all' || cat === val) ? 'flex' : 'none';
      });
    });
  });

  // Contact form — submits to /api/contact (Resend)
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const toast = document.getElementById('form-toast');

  if (form && toast) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

      const nameVal    = (document.getElementById('name')    as HTMLInputElement).value.trim();
      const emailVal   = (document.getElementById('email')   as HTMLInputElement).value.trim();
      const messageVal = (document.getElementById('message') as HTMLTextAreaElement).value.trim();

      // Client-side guard
      if (!nameVal || !emailVal || !messageVal) {
        toast.className = 'p-3 rounded-lg text-sm bg-red-50 text-red-600 border border-red-100';
        toast.textContent = 'Please fill in all fields.';
        toast.classList.remove('hidden');
        return;
      }

      if (btn) { btn.textContent = 'Sending…'; btn.disabled = true; }
      toast.classList.add('hidden');

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: nameVal, email: emailVal, message: messageVal }),
        });

        const data = await res.json();

        if (res.ok) {
          toast.className = 'p-3 rounded-lg text-sm bg-green-50 text-green-700 border border-green-100';
          toast.textContent = "Message sent — I'll reply shortly!";
          toast.classList.remove('hidden');
          form.reset();
        } else {
          toast.className = 'p-3 rounded-lg text-sm bg-red-50 text-red-600 border border-red-100';
          toast.textContent = data.error || 'Something went wrong. Please try again.';
          toast.classList.remove('hidden');
        }
      } catch {
        toast.className = 'p-3 rounded-lg text-sm bg-red-50 text-red-600 border border-red-100';
        toast.textContent = 'Network error. Please try again.';
        toast.classList.remove('hidden');
      } finally {
        if (btn) { btn.textContent = 'Send message'; btn.disabled = false; }
      }
    });
  }


  // Header scroll shadow
  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    if (header) header.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  // Section reveal on scroll
  const revealEls = document.querySelectorAll('.reveal');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          (entry.target as HTMLElement).style.animation = 'fade-up 0.65s cubic-bezier(0.16, 1, 0.3, 1) forwards';
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.07 }
  );
  revealEls.forEach(el => { (el as HTMLElement).style.opacity = '0'; revealObserver.observe(el); });

  // ── Typewriter for h1 ──
  const lines = ['I build things with\nPython, AI, and the web.'];
  const twEl  = document.getElementById('tw-text');
  const twCur = document.getElementById('tw-cursor');
  if (twEl) {
    const fullText = lines[0];
    let idx = 0;
    function typeNext() {
      if (idx <= fullText.length) {
        // Replace \n with <br>
        twEl.innerHTML = fullText.slice(0, idx).replace('\n', '<br />');
        idx++;
        setTimeout(typeNext, idx < 20 ? 60 : idx < fullText.length ? 55 : 0);
      } else {
        // done — keep cursor blinking for 2s then hide it
        setTimeout(() => { if (twCur) twCur.style.display = 'none'; }, 2000);
      }
    }
    // Small delay so the page settles first
    setTimeout(typeNext, 300);
  }
</script>
