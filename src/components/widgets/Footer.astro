---
import { Icon } from 'astro-icon/components';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [] } = Astro.props;

const year = new Date().getFullYear();

const navLinks = [
  { text: 'About',      href: '#about' },
  { text: 'Skills',     href: '#skills' },
  { text: 'Experience', href: '#experience' },
  { text: 'Projects',   href: '#projects' },
  { text: 'Contact',    href: '#contact' },
];
---

<footer class="relative not-prose bg-white" style="border-top: 1px solid rgb(241 245 249);">
  <!-- subtle top gradient accent -->
  <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgb(199 210 254 / 0.8), transparent);"></div>

  <div class="max-w-4xl mx-auto px-6 py-12">
    <!-- Top row -->
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10 mb-10">

      <!-- Brand block -->
      <div class="max-w-xs">
        <a href={getHomePermalink()} class="text-lg font-semibold text-gray-900 tracking-tight hover:text-indigo-600 transition-colors"
           style="font-family:'Inter Variable',system-ui,sans-serif; letter-spacing:-0.03em;">
          Muhammad Shahzad
        </a>
        <p class="text-sm text-gray-400 mt-2 leading-relaxed">
          Developer based in Lahore — building AI pipelines, automation systems, and full-stack web apps.
        </p>
        <!-- Social icons -->
        <div class="flex items-center gap-2 mt-5">
          <a href="https://github.com/Shahzad52" target="_blank" aria-label="GitHub"
             class="w-8 h-8 flex items-center justify-center rounded-lg border border-gray-100 bg-white text-gray-500 hover:text-indigo-600 hover:border-indigo-200 transition-all shadow-sm">
            <Icon name="tabler:brand-github" class="w-4 h-4" />
          </a>
          <a href="mailto:imshahzad52@gmail.com" aria-label="Email"
             class="w-8 h-8 flex items-center justify-center rounded-lg border border-gray-100 bg-white text-gray-500 hover:text-indigo-600 hover:border-indigo-200 transition-all shadow-sm">
            <Icon name="tabler:mail" class="w-4 h-4" />
          </a>
        </div>
      </div>

      <!-- Nav links -->
      <div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Navigation</p>
        <ul class="space-y-2.5">
          {navLinks.map(({ text, href }) => (
            <li>
              <a href={href}
                 class="text-sm text-gray-500 hover:text-gray-900 hover:translate-x-0.5 inline-block transition-all duration-150">
                {text}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact block -->
      <div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Get in touch</p>
        <a href="mailto:imshahzad52@gmail.com?subject=Project Inquiry"
           class="inline-flex items-center gap-2 px-4 py-2.5 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-indigo-600 transition-colors">
          <Icon name="tabler:mail" class="w-4 h-4" />
          Send an email
        </a>
        <p class="text-xs text-gray-400 mt-3">Usually replies within a few hours.</p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3 pt-6" style="border-top: 1px solid rgb(241 245 249);">
      <p class="text-xs text-gray-400">
        © {year} Muhammad Shahzad · Lahore, Pakistan
      </p>
      <p class="text-xs text-gray-400">
        Data Scientist &amp; AI Developer
      </p>
    </div>
  </div>
</footer>
