---
import '@fontsource-variable/inter';
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable', 'Inter', system-ui, sans-serif;
    --aw-font-serif: 'DM Serif Display', Georgia, serif;
    --aw-font-heading: 'DM Serif Display', Georgia, serif;
    --aw-color-primary: rgb(18 18 18);
    --aw-color-secondary: rgb(71 71 71);
    --aw-color-accent: rgb(79 70 229);
    --aw-color-text-heading: rgb(12 12 12);
    --aw-color-text-default: rgb(32 32 35);
    --aw-color-text-muted: rgb(100 100 110);
    --aw-color-bg-page: rgb(250 250 252);
    ::selection { background-color: rgb(224 231 255); color: rgb(49 46 129); }
  }
  html { color-scheme: light; }
  .dark {
    --aw-color-primary: rgb(18 18 18);
    --aw-color-secondary: rgb(71 71 71);
    --aw-color-accent: rgb(79 70 229);
    --aw-color-text-heading: rgb(12 12 12);
    --aw-color-text-default: rgb(32 32 35);
    --aw-color-text-muted: rgb(100 100 110);
    --aw-color-bg-page: rgb(250 250 252);
  }
  body {
    font-family: var(--aw-font-sans);
    background-color: rgb(250 250 252);
    color: var(--aw-color-text-default);
    -webkit-font-smoothing: antialiased;
    /* dot grid — more visible */
    background-image: radial-gradient(rgb(148 163 184 / 0.55) 1.5px, transparent 1.5px);
    background-size: 24px 24px;
  }
  h1, h2, h3 {
    font-family: var(--aw-font-heading);
    color: var(--aw-color-text-heading);
    letter-spacing: -0.02em;
  }

  /* ─── Moving diagonal lines for hero ─── */
  /* Animate transform on an oversized div — true directional flow */
  @keyframes lines-flow {
    from { transform: translate(0, 0); }
    to   { transform: translate(60px, 60px); }
  }

  .hero-lines-bg {
    /* Extend 60px beyond edges so movement never reveals a gap */
    position: absolute;
    top: -60px;
    left: -60px;
    right: -60px;
    bottom: -60px;
    background-image:
      linear-gradient(135deg, rgb(79 70 229 / 0.22) 1.5px, transparent 1.5px),
      linear-gradient(45deg,  rgb(79 70 229 / 0.14) 1px,   transparent 1px);
    background-size: 60px 60px;
    animation: lines-flow 2s linear infinite;
    will-change: transform;
  }

  /* Radial mask — keeps lines on edges, text area stays clean */
  .hero-lines-mask {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 72% 62% at 50% 50%,
      rgb(250 250 252 / 0.0) 0%,
      rgb(250 250 252 / 0.45) 55%,
      rgb(250 250 252 / 0.92) 78%,
      rgb(250 250 252) 100%);
  }

  /* Top-left colour wash — stronger */
  @keyframes wash-drift {
    0%, 100% { opacity: 0.80; transform: scale(1) translate(0, 0); }
    50%       { opacity: 1;    transform: scale(1.12) translate(24px, 12px); }
  }
  .hero-wash {
    background: conic-gradient(from 200deg at 20% 30%,
      rgb(165 180 252) 0deg, rgb(186 230 253) 120deg, transparent 200deg);
    animation: wash-drift 9s ease-in-out infinite;
    will-change: transform, opacity;
    filter: blur(52px);
  }

  /* ─── Header entrance ─── */
  @keyframes header-slide-down {
    from { opacity: 0; transform: translateY(-14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  header#header {
    animation: header-slide-down 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  header#header.scrolled {
    box-shadow: 0 1px 0 rgb(0 0 0 / 0.06), 0 4px 16px rgb(0 0 0 / 0.04);
  }

  /* ─── Typewriter cursor ─── */
  .tw-cursor {
    display: inline-block;
    width: 3px;
    height: 0.85em;
    background: rgb(79 70 229);
    border-radius: 2px;
    margin-left: 4px;
    vertical-align: middle;
    animation: blink 0.9s step-end infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* ─── Section reveal ─── */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ─── Scrollbar ─── */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgb(203 213 225); border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: rgb(148 163 184); }
</style>
